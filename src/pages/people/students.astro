  { name: "刘天灵", grade: "2021级", research: "医学影像处理、多模态学习" },
  { name: "胡连宇", grade: "2021级", research: "多模态学习、视频理解、手语理解" },
  { name: "田云彤", grade: "2021级", research: "领域自适应、持续学习、医学影像" },
  { name: "王立凯", grade: "2022级", research: "视频分析与理解" },
  { name: "张麒",   grade: "2022级", research: "计算机视觉、深度学习" },
  { name: "陈强",   grade: "2023级", research: "多模态、分割" },
  { name: "巩一璞", grade: "2023级", research: "计算机视觉、文化遗产预防性保护" },
  { name: "李佳曦", grade: "2024级", research: "智能医学影像分析、领域自适应" },
  { name: "张向群", grade: "2024级", research: "研究方向待定" },
