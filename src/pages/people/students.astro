---
import Layout from '../../layouts/Layout.astro';

const avatarColors = [
  'bg-red-700', 'bg-amber-700', 'bg-emerald-700', 'bg-blue-700',
  'bg-purple-700', 'bg-pink-700', 'bg-teal-700', 'bg-indigo-700',
  'bg-orange-700', 'bg-cyan-700', 'bg-rose-700', 'bg-violet-700',
];

function getColor(name: string) {
  let hash = 0;
  for (const ch of name) hash = ch.charCodeAt(0) + ((hash << 5) - hash);
  return avatarColors[Math.abs(hash) % avatarColors.length];
}

function getInitial(name: string) {
  return name.slice(0, 1);
}

interface Student {
  name: string;
  grade: string;
  research: string;
}

