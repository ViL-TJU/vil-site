---
import Layout from '../layouts/Layout.astro';

const researchAreas = [
  {
    title: "视频内容分析",
    desc: "目标检测与跟踪、多目标关联感知、行为分析理解",
    image: "/images/research/video-analysis.svg",
    color: "from-red-50 to-orange-50",
    border: "group-hover:border-tju-red",
  },
  {
    title: "多模态理解",
    desc: "多模态学习、手语理解、跨模态信息融合",
    image: "/images/research/multimodal.svg",
    color: "from-blue-50 to-indigo-50",
    border: "group-hover:border-blue-600",
  },
  {
    title: "医学影像处理",
    desc: "AI辅助诊断、医学图像分析、与多家医院合作",
    image: "/images/research/medical.svg",
    color: "from-emerald-50 to-teal-50",
    border: "group-hover:border-emerald-600",
  },
  {
    title: "数字文化遗产",
    desc: "文物表面监测、敦煌研究院和湖南博物院合作",
    image: "/images/research/cultural-heritage.svg",
    color: "from-amber-50 to-yellow-50",
    border: "group-hover:border-amber-600",
  },
];

const stats = [
  { number: "100+", label: "发表论文", icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" },
  { number: "30+", label: "发明专利", icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" },
  { number: "6", label: "研究方向", icon: "M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" },
  { number: "50+", label: "团队成员", icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" },
];

const news = [
  {
    date: "2024-01-25",
    title: "实验室在数字文化遗产保护领域取得新进展",
    summary: "相关成果已在敦煌研究院和湖南博物院部署使用...",
    tag: "科研成果",
  },
  {
    date: "2024-01-20",
    title: "多篇论文被顶级会议录用",
    summary: "实验室成员在CVPR、ICCV等顶级会议发表论文...",
    tag: "学术论文",
  },
];
---

<Layout title="首页">
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gray-950">
    <!-- Background image with overlay -->
    <div class="absolute inset-0">
      <img src="/images/banner1.jpg" alt="" class="h-full w-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-gray-950/90 via-gray-950/70 to-gray-950/50"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-gray-950/80 via-transparent to-gray-950/30"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex min-h-[600px] items-center py-24 lg:min-h-[680px] lg:py-32">
        <div class="max-w-3xl space-y-8">
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium text-white backdrop-blur-sm">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-red-400 opacity-75"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-red-500"></span>
            </span>
            诚聘博士后、科研助理
          </div>

          <!-- Heading -->
          <h1 class="text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl xl:text-7xl">
            视觉智能实验室
            <span class="mt-2 block bg-gradient-to-r from-red-400 to-red-300 bg-clip-text text-transparent">
              Visual Intelligence Lab
            </span>
          </h1>

          <!-- Description -->
          <p class="max-w-2xl text-lg leading-relaxed text-gray-300 sm:text-xl">
            天津大学智能与计算学部视觉智能实验室，致力于计算机视觉、视频分析、医学影像处理等领域的研究。国家文物局重点科研基地核心技术团队。
          </p>

          <!-- CTA Buttons -->
          <div class="flex flex-wrap gap-4 pt-2">
            <a href="/research" class="inline-flex items-center gap-2 rounded-lg bg-tju-red px-7 py-3.5 text-sm font-semibold text-white shadow-lg shadow-red-900/30 transition-all hover:-translate-y-0.5 hover:bg-red-800 hover:shadow-xl hover:shadow-red-900/40">
              了解研究方向
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a href="/join" class="inline-flex items-center gap-2 rounded-lg border border-white/25 px-7 py-3.5 text-sm font-semibold text-white backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:border-white/50 hover:bg-white/10">
              加入我们
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="relative z-10 border-b border-gray-100 bg-white shadow-sm">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 divide-x divide-gray-100 md:grid-cols-4">
        {stats.map((stat) => (
          <div class="group px-4 py-8 text-center transition-colors hover:bg-red-50/50 sm:py-10">
            <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-full bg-red-50 text-tju-red transition-colors group-hover:bg-tju-red group-hover:text-white">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={stat.icon} />
              </svg>
            </div>
            <div class="text-3xl font-bold tracking-tight text-gray-900 lg:text-4xl">{stat.number}</div>
            <div class="mt-1 text-sm font-medium text-gray-500">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Research Areas -->
  <section class="bg-gray-50/50 py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Section Header -->
      <div class="mx-auto mb-16 max-w-2xl text-center">
        <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-tju-red">Research Areas</p>
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 lg:text-4xl">研究方向</h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-600">
          聚焦前沿技术，推动学术创新
        </p>
      </div>

      <!-- Research Cards -->
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {researchAreas.map((area) => (
          <a href="/research" class="group relative flex flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
            <!-- SVG Illustration -->
            <div class={`flex items-center justify-center bg-gradient-to-br ${area.color} p-6 transition-all duration-300`}>
              <img
                src={area.image}
                alt={area.title}
                class="h-32 w-32 object-contain transition-transform duration-500 group-hover:scale-110"
              />
            </div>
            <!-- Content -->
            <div class="flex flex-1 flex-col p-6">
              <h3 class="text-lg font-semibold text-gray-900 transition-colors group-hover:text-tju-red">
                {area.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-gray-500">
                {area.desc}
              </p>
              <div class="mt-4 flex items-center gap-1 pt-2 text-xs font-medium text-tju-red opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                了解更多
                <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-12 text-center">
        <a href="/research" class="inline-flex items-center gap-2 text-sm font-semibold text-tju-red transition-colors hover:text-red-800">
          查看全部研究方向
          <svg class="h-4 w-4 transition-transform hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- News & Recruitment -->
  <section class="bg-white py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-12 lg:grid-cols-5">

        <!-- Latest News (3 cols) -->
        <div class="lg:col-span-3">
          <div class="mb-8 flex items-center justify-between">
            <div>
              <p class="mb-1 text-sm font-semibold uppercase tracking-widest text-tju-red">News</p>
              <h2 class="text-2xl font-bold tracking-tight text-gray-900 lg:text-3xl">最新动态</h2>
            </div>
            <a href="/news" class="inline-flex items-center gap-1 text-sm font-medium text-gray-500 transition-colors hover:text-tju-red">
              查看更多
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>

          <div class="space-y-4">
            {news.map((item) => (
              <article class="group rounded-xl border border-gray-100 bg-white p-6 shadow-sm transition-all duration-200 hover:border-gray-200 hover:shadow-md">
                <div class="flex items-start gap-4">
                  <div class="hidden shrink-0 sm:block">
                    <div class="flex h-14 w-14 flex-col items-center justify-center rounded-lg bg-red-50 text-tju-red transition-colors group-hover:bg-tju-red group-hover:text-white">
                      <span class="text-lg font-bold leading-none">{item.date.split('-')[2]}</span>
                      <span class="mt-0.5 text-[10px] font-medium leading-none opacity-70">{item.date.split('-')[1]}月</span>
                    </div>
                  </div>
                  <div class="min-w-0 flex-1">
                    <div class="mb-2 flex items-center gap-3">
                      <span class="rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-600">{item.tag}</span>
                      <time class="text-xs text-gray-400 sm:hidden">{item.date}</time>
                    </div>
                    <h3 class="font-semibold text-gray-900 transition-colors group-hover:text-tju-red">
                      {item.title}
                    </h3>
                    <p class="mt-1.5 text-sm leading-relaxed text-gray-500">{item.summary}</p>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- Recruitment Card (2 cols) -->
        <div class="lg:col-span-2">
          <div class="overflow-hidden rounded-2xl bg-gradient-to-br from-gray-900 to-gray-800 p-8 shadow-xl lg:p-10">
            <!-- Decorative corner accent -->
            <div class="absolute right-0 top-0 h-32 w-32 translate-x-8 -translate-y-8 rounded-full bg-tju-red/20 blur-2xl"></div>

            <div class="relative">
              <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-3 py-1.5 text-xs font-medium text-white/80">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                长期招聘
              </div>

              <h2 class="mb-3 text-2xl font-bold text-white">
                诚聘博士后 / 科研助理
              </h2>
              <p class="mb-8 text-sm leading-relaxed text-gray-400">
                欢迎具有计算机视觉、机器学习、医学影像处理等背景的优秀人才加入我们的团队。提供有竞争力的薪酬待遇和良好的科研环境。
              </p>

              <ul class="mb-8 space-y-3">
                <li class="flex items-center gap-3 text-sm text-gray-300">
                  <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-tju-red/20">
                    <svg class="h-3 w-3 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  博士后年薪 30-50万
                </li>
                <li class="flex items-center gap-3 text-sm text-gray-300">
                  <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-tju-red/20">
                    <svg class="h-3 w-3 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  充足的科研经费支持
                </li>
                <li class="flex items-center gap-3 text-sm text-gray-300">
                  <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-tju-red/20">
                    <svg class="h-3 w-3 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  优秀的团队合作氛围
                </li>
              </ul>

              <a href="/join" class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-tju-red px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-red-800">
                了解详情
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>
