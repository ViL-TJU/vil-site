---
const navItems = [
  { href: "/", label: "首页" },
  { href: "/about", label: "关于我们" },
  {
    href: "/people",
    label: "团队成员",
    children: [
      { href: "/people/faculty", label: "教师" },
      { href: "/people/students", label: "在读学生" },
      { href: "/people/alumni", label: "毕业学生" },
    ]
  },
  { href: "/research", label: "研究方向" },
  { href: "/publications", label: "学术成果" },
  { href: "/news", label: "新闻动态" },
  { href: "/join", label: "加入我们" },
];

const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-3 group">
        <img src="/images/vil-logo.png" alt="ViL Logo" class="h-10 w-auto group-hover:scale-105 transition-transform brightness-0" />
        <span class="font-semibold text-gray-900 hidden sm:block">视觉智能实验室</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-1">
        {navItems.map((item) => (
          <div class="relative group">
            <a
              href={item.href}
              class:list={[
                "px-4 py-2 rounded-md text-sm font-medium transition-colors",
                currentPath === item.href || currentPath.startsWith(item.href + '/')
                  ? "text-tju-red bg-red-50"
                  : "text-gray-700 hover:text-tju-red hover:bg-gray-50"
              ]}
            >
              {item.label}
            </a>

            {item.children && (
              <div class="absolute top-full left-0 mt-1 w-40 bg-white rounded-lg shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-4 py-2 text-sm text-gray-700 hover:text-tju-red hover:bg-red-50 first:rounded-t-lg last:rounded-b-lg"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-md text-gray-700 hover:text-tju-red hover:bg-gray-100"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white">
    <div class="px-2 pt-2 pb-3 space-y-1">
      {navItems.map((item) => (
        <div>
          <a
            href={item.href}
            class:list={[
              "block px-3 py-2 rounded-md text-base font-medium",
              currentPath === item.href
                ? "text-tju-red bg-red-50"
                : "text-gray-700 hover:text-tju-red hover:bg-gray-50"
            ]}
          >
            {item.label}
          </a>

          {item.children && (
            <div class="pl-4">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class="block px-3 py-2 rounded-md text-sm text-gray-600 hover:text-tju-red hover:bg-gray-50"
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</nav>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
